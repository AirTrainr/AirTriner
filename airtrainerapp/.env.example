# ========================================
# AirTrainr Mobile App - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# App (Next.js web origin — mobile API routes live here)
EXPO_PUBLIC_APP_URL=http://localhost:3000

# Platform default currency (USD/CAD/EUR/GBP/AUD/INR)
EXPO_PUBLIC_PLATFORM_CURRENCY=CAD

# Google Places
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your-google-places-api-key

# Cloudinary (same account as web — use the same cloud name and upload preset)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
